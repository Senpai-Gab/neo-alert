{
  "name": "neo-alert",
  "version": "1.0.0",
  "description": "A futuristic glassmorphism toast notification library. Zero dependencies, framework-agnostic.",
  "main": "dist/neo-alert.js",
  "module": "dist/neo-alert.esm.js",
  "browser": "dist/neo-alert.js",
  "exports": {
    ".": {
      "import": "./dist/neo-alert.esm.js",
      "require": "./dist/neo-alert.js",
      "default": "./dist/neo-alert.js"
    }
  },
  "scripts": {
    "start": "npx serve . -p 3000",
    "dev": "npx serve . -p 3000"
  },
  "keywords": [
    "toast",
    "notification",
    "alert",
    "glassmorphism",
    "neo-alert",
    "ui",
    "vanilla-js"
  ],
  "author": "senpai-gab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/senpai-gab/neo-alert.git"
  },
  "homepage": "https://senpai-gab.github.io/neo-alert",
  "bugs": {
    "url": "https://github.com/senpai-gab/neo-alert/issues"
  },
  "files": [
    "dist/",
    "README.md"
  ]
}
